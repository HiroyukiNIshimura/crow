{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "Node16",
        "moduleResolution": "Node16",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "incremental": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
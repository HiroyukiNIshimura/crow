generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  member
}

enum AuthProvider {
  local
  oidc
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  displayName    String
  role           UserRole       @default(member)
  passwordHash   String?
  provider       AuthProvider   @default(local)
  providerUserId String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sessions       Session[]
  workLogs       WorkLog[]
  dailyNotes     DailyNote[]
  authAuditLogs  AuthAuditLog[]

  @@map("users")
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  sessionTokenHash String    @unique
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  lastSeenAt       DateTime  @default(now())
  ipAddress        String?
  userAgent        String?
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthAuditLog {
  id                String   @id @default(cuid())
  userId            String?
  eventType         String
  emailOrIdentifier String?
  ipAddress         String?
  userAgent         String?
  metadata          Json?
  createdAt         DateTime @default(now())
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("auth_audit_logs")
}

model WorkLog {
  id              String   @id @default(cuid())
  userId          String
  workDate        DateTime
  title           String
  note            String?
  durationMinutes Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workDate])
  @@map("work_logs")
}

model DailyNote {
  id        String   @id @default(cuid())
  userId    String
  workDate  DateTime
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workDate])
  @@index([userId])
  @@map("daily_notes")
}
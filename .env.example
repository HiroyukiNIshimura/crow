# Authentication placeholders
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=crow_session
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crow
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SESSION_COOKIE_NAME=crow_session
WEB_PORT=3000
API_PORT=3001

# Initial admin account (provisioned on startup if ADMIN_USER_ENABLED=true)
ADMIN_USER_ENABLED=true
ADMIN_USER_EMAIL=admin@example.com
ADMIN_USER_PASSWORD=password123!
ADMIN_USER_NAME='Crow Admin'

# Session / auth controls
SESSION_MAX_AGE_SECONDS=86400
SESSION_IDLE_TIMEOUT_SECONDS=1800
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_MAX=5
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW='1 minute'
PASSWORD_RESET_EXPIRE_MINUTES=60

# Mail (SMTP)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Crow <no-reply@example.com>"
INVITATION_EXPIRE_HOURS=48

# Optional OIDC / OAuth placeholders
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
